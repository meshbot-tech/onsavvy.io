  "templates": [
    {
      "id": "tpl-001",
      "name": "Initial Outreach - WhatsApp",
      "channel": "whatsapp",
      "type": "outreach",
      "subject": "",
      "body": "Hi {{name}}, I'm from Savvion. I noticed you're interested in {{service}}. Would love to discuss how we can help. When is a good time to chat?",
      "variables": ["name", "service"],
      "createdAt": "2026-01-20",
      "isActive": true
    },
    {
      "id": "tpl-002",
      "name": "Proposal Follow-up - Email",
      "channel": "email",
      "type": "follow-up",
      "subject": "Following up on your Savvion proposal",
      "body": "Dear {{name}},\n\nI hope you're well. I'm writing to check if you had a chance to review the {{service}} proposal we sent on {{date}}.\n\nHappy to hop on a quick call to clarify anything.\n\nBest,\nSavvion Team",
      "variables": ["name", "service", "date"],
      "createdAt": "2026-02-10",
      "isActive": true
    },
    {
      "id": "tpl-003",
      "name": "Meeting Reminder - SMS",
      "channel": "sms",
      "type": "reminder",
      "subject": "",
      "body": "Reminder: Meeting with Savvion today at {{time}}. Reply YES to confirm or RESCHEDULE to change.",
      "variables": ["time"],
      "createdAt": "2026-03-05",
      "isActive": true
    },
    {
      "id": "tpl-004",
      "name": "Quote Response - Email",
      "channel": "email",
      "type": "quote",
      "subject": "Your Savvion quote ({{quoteId}})",
      "body": "Hi {{name}},\n\nThank you for your interest in {{service}}. Attached is your custom quote.\n\nQuote ID: {{quoteId}}\nValid until: {{expiry}}\n\nLet me know if you need any adjustments.\n\nRegards,\nSavvion Team",
      "variables": ["name", "service", "quoteId", "expiry"],
      "createdAt": "2026-03-15",
      "isActive": true
    },
    {
      "id": "tpl-005",
      "name": "Welcome Onboarding - Email",
      "channel": "email",
      "type": "onboarding",
      "subject": "Welcome to Savvion – Let's get started!",
      "body": "Hello {{name}},\n\nWelcome aboard! We're excited to build {{service}} for you.\n\nNext steps:\n1. Kick-off call scheduled for {{kickoffDate}}\n2. Project portal access will be sent by {{portalDate}}\n3. First milestone delivery: {{milestoneDate}}\n\nReach out anytime.\n\nCheers,\nSavvion Team",
      "variables": ["name", "service", "kickoffDate", "portalDate", "milestoneDate"],
      "createdAt": "2026-04-01",
      "isActive": true
    }
  ],
